{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Related Entities Manifest Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "related": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "required": ["schema_version", "generated_at", "related"]
}
