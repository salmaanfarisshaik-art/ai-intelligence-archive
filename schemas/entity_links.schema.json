{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Entity Links Manifest Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": ["source_id", "target_id", "type"]
      }
    }
  },
  "required": ["schema_version", "generated_at", "links"]
}
